{
  "name": "opendragon",
  "version": "1.1.0",
  "description": "Multi-provider AI CLI tool",
  "main": "dist/index.js",
  "bin": {
    "dragon": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/dragon.js --banner:js=\"#!/usr/bin/env node\"",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "ai",
    "cli",
    "openai",
    "anthropic",
    "gemini",
    "deepseek"
  ],
  "author": "Xu Haiqing",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.21.0",
    "@inquirer/prompts": "^7.4.0",
    "chalk": "^5.4.1",
    "cheerio": "^1.0.0",
    "commander": "^13.1.0",
    "figlet": "^1.8.0",
    "glob": "^11.0.0",
    "openai": "^4.91.0",
    "ora": "^8.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.0",
    "@types/node": "^22.14.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "esbuild": "^0.25.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.5"
  }
}
