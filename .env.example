# OpenDragon Environment Variables

# Logging Configuration
# 0 = DEBUG, 1 = INFO, 2 = WARN, 3 = ERROR, 4 = SILENT
DRAGON_LOG_LEVEL=1

# Shorthand for debug mode
# DRAGON_DEBUG=true

# Performance Monitoring
# Enable detailed performance metrics
DRAGON_PERF_MONITOR=false

# Encryption Password (optional)
# Used to decrypt encrypted configuration
# WARNING: Do not commit this file with real passwords
# DRAGON_ENCRYPTION_PASSWORD=your-secure-password

# Test Configuration
# NODE_ENV=test
